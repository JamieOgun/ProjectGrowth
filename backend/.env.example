# Anthropic
ANTHROPIC_API_KEY=your_key_here

# ZenRows (used for Reddit scraping)
ZENROWS_API_KEY=

# X / Twitter API v2 (read-only — own account analytics only)
TWITTER_BEARER_TOKEN=

# Supabase server-side writes for seeds and analytics sync.
# Never expose this key to the frontend.
SUPABASE_SERVICE_ROLE_KEY=
